# Flask configuration (Change in production!)
SECRET_KEY=your-production-super-secret-key
DATABASE_URL=sqlite:///price_tracker.db
FLASK_DEBUG=False
PORT=5000
HOST=0.0.0.0

# Admin Authentication (Change credentials by setting username and generating an Argon2id hash)
ADMIN_USERNAME=admin
# Pre-generated Argon2id hash of admin password
ADMIN_PASSWORD_HASH=your-argon2id-hash-here
